class Lampada {
  bool _ligada;
  int _intensidade;
 
  // Construtor sem parâmetros
  Lampada()
      : _ligada = false,
        _intensidade = 50;
 
  // Método para ligar
  void ligar() {
    _ligada = true;
  }
 
  // Método para desligar
  void desligar() {
    _ligada = false;
  }
 
  // Aumentar intensidade (máximo 100)
  void aumentar() {
    if (_intensidade < 100) {
      _intensidade += 10;
    }
  }
 
  // Diminuir intensidade (mínimo 0)
  void diminuir() {
    if (_intensidade > 0) {
      _intensidade -= 10;
    }
  }
 
  // Exibir estado
  void exibirEstado() {
    print('Lâmpada está ${_ligada ? "ligada" : "desligada"}');
    print('Intensidade: $_intensidade');
  }
}
 
void main() {
  var l = Lampada();
 
  l.exibirEstado();
  l.ligar();
  l.aumentar();
  l.exibirEstado();
  l.diminuir();
  l.desligar();
  l.exibirEstado();
}
 
