// Classe Data
public class Data {
    private int dia;
    private int mes;
    private int ano;

    // Construtor com validação
    public Data(int dia, int mes, int ano) {
        if (dia < 1 || dia > 31) {
            throw new IllegalArgumentException("Dia deve estar entre 1 e 31.");
        }
        if (mes < 1 || mes > 12) {
            throw new IllegalArgumentException("Mês deve estar entre 1 e 12.");
        }
        if (ano <= 0) {
            throw new IllegalArgumentException("Ano deve ser maior que 0.");
        }

        this.dia = dia;
        this.mes = mes;
        this.ano = ano;
    }

    // Método para exibir a data
    public void exibirData() {
        System.out.printf("%02d/%02d/%04d%n", dia, mes, ano);
    }
}

// Classe Main
public class Main {
    public static void main(String[] args) {
        // Instanciando 3 datas diferentes
        Data data1 = new Data(1, 1, 2020);
        Data data2 = new Data(15, 6, 1995);
        Data data3 = new Data(30, 12, 2025);

        // Exibindo cada data
        data1.exibirData();
        data2.exibirData();
        data3.exibirData();
    }
}
