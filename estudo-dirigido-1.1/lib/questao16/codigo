// Classe Personagem
public class Personagem {
    private String nome;
    private int vida;
    private int ataque;

    // Construtor com validação
    public Personagem(String nome, int vida, int ataque) {
        if (nome == null || nome.trim().isEmpty()) {
            throw new IllegalArgumentException("Nome não pode ser vazio.");
        }
        if (vida <= 0) {
            throw new IllegalArgumentException("Vida deve ser maior que 0.");
        }
        if (ataque <= 0) {
            throw new IllegalArgumentException("Ataque deve ser maior que 0.");
        }
        this.nome = nome;
        this.vida = vida;
        this.ataque = ataque;
    }

    // Método para atacar outro personagem
    public void atacar(Personagem inimigo) {
        if (!estaVivo()) {
            System.out.println(nome + " não pode atacar porque está morto!");
            return;
        }
        if (!inimigo.estaVivo()) {
            System.out.println(inimigo.nome + " já está morto!");
            return;
        }
        System.out.println(nome + " ataca " + inimigo.nome + " causando " + ataque + " de dano.");
        inimigo.vida -= ataque;
        if (inimigo.vida < 0) {
            inimigo.vida = 0;
        }
    }

    // Método para exibir status do personagem
    public void exibirStatus() {
        System.out.println("Nome: " + nome + " | Vida: " + vida + " | Ataque: " + ataque);
    }

    // Método para verificar se está vivo
    public boolean estaVivo() {
        return vida > 0;
    }
}

// Classe Main
public class Main {
    public static void main(String[] args) {
        // Criando 2 personagens
        Personagem p1 = new Personagem("Guerreiro", 50, 10);
        Personagem p2 = new Personagem("Mago", 40, 12);

        // Exibindo status inicial
        System.out.println("Status inicial:");
        p1.exibirStatus();
        p2.exibirStatus();
        System.out.println();

        // Simulando combate
        int rodada = 1;
        while (p1.estaVivo() && p2.estaVivo()) {
            System.out.println("=== Rodada " + rodada + " ===");
            p1.atacar(p2);
            p2.atacar(p1);
            p1.exibirStatus();
            p2.exibirStatus();
            System.out.println();
            rodada++;
        }

        // Resultado do combate
        if (p1.estaVivo()) {
            System.out.println(p1.nome + " venceu o combate!");
        } else if (p2.estaVivo()) {
            System.out.println(p2.nome + " venceu o combate!");
        } else {
            System.out.println("Ambos os personagens morreram!");
        }
    }
}
