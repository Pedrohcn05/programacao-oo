// Classe Semaforo
public class Semaforo {
    private String corAtual;
    private int tempoRestante;

    // Constantes de tempo
    private static final int TEMPO_VERMELHO = 5;
    private static final int TEMPO_VERDE = 4;
    private static final int TEMPO_AMARELO = 2;

    // Construtor com validação
    public Semaforo(String corInicial) {
        if (!corInicial.equalsIgnoreCase("vermelho") &&
            !corInicial.equalsIgnoreCase("verde") &&
            !corInicial.equalsIgnoreCase("amarelo")) {
            throw new IllegalArgumentException("Cor inválida. Use vermelho, verde ou amarelo.");
        }
        this.corAtual = corInicial.toLowerCase();
        reiniciarTempo();
    }

    // Método para trocar cor seguindo a ordem vermelho -> verde -> amarelo -> vermelho
    public void trocarCor() {
        switch (corAtual) {
            case "vermelho":
                corAtual = "verde";
                break;
            case "verde":
                corAtual = "amarelo";
                break;
            case "amarelo":
                corAtual = "vermelho";
                break;
        }
        reiniciarTempo();
    }

    // Método para reduzir o tempo restante
    public void reduzirTempo() {
        tempoRestante--;
        if (tempoRestante <= 0) {
            trocarCor();
        }
    }

    // Método para reiniciar o tempo conforme a cor atual
    private void reiniciarTempo() {
        switch (corAtual) {
            case "vermelho":
                tempoRestante = TEMPO_VERMELHO;
                break;
            case "verde":
                tempoRestante = TEMPO_VERDE;
                break;
            case "amarelo":
                tempoRestante = TEMPO_AMARELO;
                break;
        }
    }

    // Método para exibir o estado atual
    public void exibirEstado() {
        String emoji = "";
        switch (corAtual) {
            case "vermelho": emoji = "🔴"; break;
            case "verde": emoji = "🟢"; break;
            case "amarelo": emoji = "🟡"; break;
        }
        System.out.println("Semáforo: " + emoji + " (" + corAtual + ") - Tempo restante: " + tempoRestante);
    }
}

// Classe Main
public class Main {
    public static void main(String[] args) {
        // Instanciando 1 semáforo com cor inicial vermelho
        Semaforo semaforo = new Semaforo("vermelho");

        // Simulando alguns ciclos (ex.: 20 unidades de tempo)
        for (int i = 1; i <= 20; i++) {
            System.out.println("Unidade de tempo " + i);
            semaforo.exibirEstado();
            semaforo.reduzirTempo();
            System.out.println();
        }
    }
}
