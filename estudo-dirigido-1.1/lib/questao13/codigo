// Classe Pedido
public class Pedido {
    private int numero;
    private Produto produto;
    private int quantidade;

    // Construtor com validação
    public Pedido(int numero, Produto produto, int quantidade) {
        if (numero <= 0) {
            throw new IllegalArgumentException("Número do pedido deve ser maior que 0.");
        }
        if (produto == null) {
            throw new IllegalArgumentException("Produto deve ser fornecido.");
        }
        if (quantidade <= 0) {
            throw new IllegalArgumentException("Quantidade deve ser maior que 0.");
        }

        this.numero = numero;
        this.produto = produto;
        this.quantidade = quantidade;
    }

    // Calcula o total do pedido usando o preço do produto e quantidade
    public double calcularTotal() {
        return produto.getPrecoUnitario() * quantidade;
    }

    // Exibe os dados completos do pedido
    public void exibirPedido() {
        System.out.println("===== Pedido Nº " + numero + " =====");
        produto.exibirResumo(); // exibe resumo do produto
        System.out.println("Quantidade: " + quantidade);
        System.out.printf("Total do pedido: R$ %.2f%n", calcularTotal());
        System.out.println("==============================\n");
    }
}

// Classe Produto com método getPrecoUnitario() necessário
class Produto {
    private int codigo;
    private String nome;
    private double precoUnitario;
    private int quantidade;

    public Produto(int codigo, String nome, double precoUnitario, int quantidade) {
        this.codigo = codigo;
        this.nome = nome;
        this.precoUnitario = precoUnitario;
        this.quantidade = quantidade;
    }

    public double getPrecoUnitario() {
        return precoUnitario;
    }

    public void exibirResumo() {
        System.out.println("----- Resumo do Produto -----");
        System.out.println("Código: " + codigo);
        System.out.println("Nome: " + nome);
        System.out.printf("Preço unitário: R$ %.2f%n", precoUnitario);
        System.out.println("-----------------------------");
    }
}

// Classe Main
public class Main {
    public static void main(String[] args) {
        // Criando 2 produtos
        Produto p1 = new Produto(1, "Notebook", 3500.00, 3);
        Produto p2 = new Produto(2, "Smartphone", 1500.00, 5);

        // Criando 2 pedidos diferentes
        Pedido pedido1 = new Pedido(101, p1, 2);
        Pedido pedido2 = new Pedido(102, p2, 3);

        // Exibindo dados completos de cada pedido
        pedido1.exibirPedido();
        pedido2.exibirPedido();
    }
}
