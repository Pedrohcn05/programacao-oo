// Classe Contador
public class Contador {
    private int valor;

    // Construtor com valor inicial
    public Contador(int valorInicial) {
        if (valorInicial < 0) {
            throw new IllegalArgumentException("O valor inicial deve ser maior ou igual a 0.");
        }
        this.valor = valorInicial;
    }

    // Método para incrementar
    public void incrementar() {
        valor++;
    }

    // Método para decrementar
    public void decrementar() {
        if (valor > 0) {
            valor--;
        } else {
            System.out.println("O contador já está em 0, não pode ser negativo.");
        }
    }

    // Método para zerar
    public void zerar() {
        valor = 0;
    }

    // Método para exibir valor atual
    public void exibirValor() {
        System.out.println("Valor atual do contador: " + valor);
    }
}

// Classe Main
public class Main {
    public static void main(String[] args) {
        // Instanciando dois contadores diferentes
        Contador contador1 = new Contador(5);
        Contador contador2 = new Contador(0);

        // Operações com contador1
        contador1.exibirValor();
        contador1.incrementar();
        contador1.exibirValor();
        contador1.decrementar();
        contador1.exibirValor();
        contador1.zerar();
        contador1.exibirValor();

        // Operações com contador2
        contador2.exibirValor();
        contador2.decrementar(); // já está em 0, não diminui
        contador2.incrementar();
        contador2.exibirValor();
    }
}
